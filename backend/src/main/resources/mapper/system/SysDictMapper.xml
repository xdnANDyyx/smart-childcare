<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhyyt.nursery.module.system.mapper.SysDictMapper">

    <select id="selectDictDataByType" resultType="com.zhyyt.nursery.module.system.entity.SysDictData">
        SELECT * FROM sys_dict_data WHERE dict_type = #{dictType} AND status = '0' ORDER BY dict_sort
    </select>

</mapper>
